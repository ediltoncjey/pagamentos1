APP_NAME="SISTEM_PAY"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/sistem_pay
APP_TIMEZONE=Africa/Maputo
APP_KEY=change-me-with-random-value

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sistem_pay
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

PAYMENT_PROVIDER=rozvitech
PAYMENT_API_BASE_URL=https://pay.rozvitech.com/api/v1
PAYMENT_API_KEY=
PAYMENT_STATUS_ENDPOINT_TEMPLATE=/payments/{reference}
PAYMENT_DEFAULT_GATEWAY=mpesa
PAYMENT_GATEWAY_MPESA_ENABLED=true
PAYMENT_GATEWAY_MPESA_CONFIGURED=true
PAYMENT_GATEWAY_MPESA_NAME="M-Pesa"
PAYMENT_GATEWAY_MPESA_PROVIDER=rozvitech
PAYMENT_GATEWAY_MPESA_MIN_AMOUNT=20
PAYMENT_GATEWAY_EMOLA_ENABLED=false
PAYMENT_GATEWAY_EMOLA_CONFIGURED=false
PAYMENT_GATEWAY_EMOLA_NAME="e-Mola"
PAYMENT_GATEWAY_EMOLA_PROVIDER=emola
PAYMENT_GATEWAY_EMOLA_BASE_URL=
PAYMENT_GATEWAY_EMOLA_API_KEY=
PAYMENT_GATEWAY_EMOLA_STATUS_ENDPOINT_TEMPLATE=/payments/{reference}
PAYMENT_GATEWAY_VISA_ENABLED=false
PAYMENT_GATEWAY_VISA_CONFIGURED=false
PAYMENT_GATEWAY_VISA_NAME=Visa
PAYMENT_GATEWAY_VISA_PROVIDER=visa
PAYMENT_GATEWAY_VISA_BASE_URL=
PAYMENT_GATEWAY_VISA_API_KEY=
PAYMENT_GATEWAY_VISA_STATUS_ENDPOINT_TEMPLATE=/payments/{reference}
PAYMENT_GATEWAY_PAYPAL_ENABLED=false
PAYMENT_GATEWAY_PAYPAL_CONFIGURED=false
PAYMENT_GATEWAY_PAYPAL_NAME=PayPal
PAYMENT_GATEWAY_PAYPAL_PROVIDER=paypal
PAYMENT_GATEWAY_PAYPAL_BASE_URL=
PAYMENT_GATEWAY_PAYPAL_API_KEY=
PAYMENT_GATEWAY_PAYPAL_STATUS_ENDPOINT_TEMPLATE=/payments/{reference}
PAYMENT_TIMEOUT_SECONDS=30
PAYMENT_ENABLE_CALLBACK=true
PAYMENT_ENABLE_POLLING=true
PAYMENT_RETRY_ATTEMPTS=3
PAYMENT_RETRY_BASE_DELAY_MS=250
PAYMENT_POLL_INTERVAL_SECONDS=90
PAYMENT_POLL_MAX_RETRIES=20
PAYMENT_POLL_BATCH_SIZE=100
PAYMENT_POLL_SECRET=
PAYMENT_CALLBACK_SIGNATURE_HEADER=X-Signature
PAYMENT_CALLBACK_SECRET=
DOWNLOAD_TOKEN_TTL_SECONDS=86400
DOWNLOAD_MAX_DOWNLOADS=5
LEDGER_RECONCILE_DEFAULT_LIMIT=100
LEDGER_RECONCILE_MAX_LIMIT=1000
REPORT_DEFAULT_MONTHS=6
REPORT_MAX_MONTHS=24
REPORT_DEFAULT_HISTORY_LIMIT=25
REPORT_MAX_HISTORY_LIMIT=200
REPORT_DEFAULT_TOP_RESELLERS=10
REPORT_MAX_TOP_RESELLERS=50
REPORT_DEFAULT_EXPORT_LIMIT=500

EMAIL_TRANSPORT=smtp
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_ENCRYPTION=tls
EMAIL_FROM_ADDRESS=no-reply@sistempay.local
EMAIL_FROM_NAME="SISTEM_PAY"
EMAIL_TIMEOUT_SECONDS=20
EMAIL_ALLOW_INSECURE=false

SECURITY_BCRYPT_COST=12
SECURITY_CSRF_TOKEN_NAME=_csrf
SECURITY_RATE_LIMIT_MAX=120
SECURITY_RATE_LIMIT_WINDOW_SECONDS=60
SECURITY_IDEMPOTENCY_TTL=3600
SECURITY_SESSION_COOKIE_NAME=sistem_pay_session
SECURITY_SESSION_LIFETIME=7200
SECURITY_SESSION_SAMESITE=Lax
SECURITY_SESSION_SECURE=false
SECURITY_SESSION_ENFORCE_FINGERPRINT=true
SECURITY_SESSION_ROTATE_INTERVAL_SECONDS=900
SECURITY_TRUSTED_PROXIES=
SECURITY_CSRF_ENFORCE_ORIGIN=true
SECURITY_CSRF_TRUSTED_ORIGINS=localhost,127.0.0.1
SECURITY_HEADERS_HSTS_ENABLED=false
SECURITY_HEADERS_HSTS_MAX_AGE=31536000
SECURITY_AUDIT_TRAIL_ENABLED=true
SECURITY_AUDIT_TRAIL_EXCLUDE_PREFIXES=/health,/api/health
SECURITY_LOGIN_MAX_ATTEMPTS=5
SECURITY_LOGIN_WINDOW_SECONDS=900
SECURITY_LOGIN_LOCKOUT_SECONDS=900
SECURITY_RATE_LIMIT_LOGIN_MAX=15
SECURITY_RATE_LIMIT_LOGIN_WINDOW_SECONDS=300
SECURITY_RATE_LIMIT_CALLBACK_MAX=600
SECURITY_RATE_LIMIT_CALLBACK_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_CHECKOUT_MAX=50
SECURITY_RATE_LIMIT_CHECKOUT_WINDOW_SECONDS=300
SECURITY_PASSWORD_REQUIRE_MIXED_CASE=true
SECURITY_PASSWORD_REQUIRE_NUMBER=true
SECURITY_PASSWORD_REQUIRE_SYMBOL=true

AUTH_BOOTSTRAP_DEFAULT_ADMIN=true
AUTH_DEFAULT_ADMIN_NAME="System Admin"
AUTH_DEFAULT_ADMIN_EMAIL=admin@sistempay.local
AUTH_DEFAULT_ADMIN_PASSWORD=ChangeMe@123

PRODUCT_IMAGE_MAX_BYTES=5242880
PRODUCT_DIGITAL_MAX_BYTES=104857600
PRODUCT_IMAGE_EXTENSIONS=jpg,jpeg,png,webp
PRODUCT_DIGITAL_EXTENSIONS=pdf,zip,rar,7z,doc,docx,ppt,pptx,xls,xlsx,txt,mp4,mp3,epub
